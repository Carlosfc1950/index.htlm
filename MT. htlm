    if (!precio||isNaN(precio)||+precio<=0){errEl.textContent='Ingresá un precio válido.';errEl.style.display='block';return;}
    if (!sellerN){errEl.textContent='Ingresá tu nombre.';errEl.style.display='block';return;}
    if (waD.length<10){errEl.textContent='Ingresá tu código de área y número.';errEl.style.display='block';return;}
