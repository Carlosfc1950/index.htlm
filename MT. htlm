var detailPage = document.getElementById('detailPage');

function openDetail(id) {
  var p = products.find(function(x){ return x.id === id; });
  if (!p) return;

  var isMT = p.owner === 'mt';
  document.getElementById('detailTitle').textContent = p.name;

  // Gallery
  var gallHtml = '';
  if (p.photos.length) {
    gallHtml = '<div class="detail-gallery">'
      + '<img class="detail-main-img" id="dmImg" src="'+p.photos[0]+'" alt="">';
    if (p.photos.length > 1) {
      gallHtml += '<div class="detail-thumbs">'
        + p.photos.map(function(ph,i){
            return '<img src="'+ph+'" class="'+(i===0?'active':'')+'" data-src="'+ph+'">';
          }).join('')
        + '</div>';
    }
    gallHtml += '</div>';
  } else {
    gallHtml = '<div class="detail-main-emoji">'+p.icon+'</div>';
  }

  // Badges
  var badges = '';
  if (isMT) badges += '<span class="detail-badge mt">🏭 Mercado Técnico</span>';
  else       badges += '<span class="detail-badge tecnico">👤 '+(p.sellerName||'Técnico')+'</span>';
  if (p.badge) {
    var bc = p.badge==='OFERTA'?'offer': p.badge==='NUEVO'||p.badge==='NEW'?'new': p.badge==='DESTACADO'||p.badge==='MÁS VENDIDO'?'featured': 'used';
    badges += '<span class="detail-badge '+bc+'">'+p.badge+'</span>';
  }

  // Actions
  var actions = '';
  if (isMT) {
    actions = '<button class="btnblock" style="margin-bottom:11px" id="dpBtnComprar">🛒 Comprar ahora</button>'
      + '<a class="btnwa-block" href="'+waLink(WA_SOPORTE,'Hola, quiero consultar sobre: '+p.name+' ('+p.price+')')+'" target="_blank" rel="noopener noreferrer">'+WA_MD+' Consultar por WhatsApp</a>';
  } else {
    var sw = p.wa || WA_SOPORTE;
    actions = '<a class="btnwa-block" href="'+waLink(sw,'Hola, vi tu publicación de *'+p.name+'* por *'+p.price+'* en Mercado Técnico. ¿Está disponible?')+'" target="_blank" rel="noopener noreferrer">'+WA_MD+' Contactar al vendedor por WhatsApp</a>';
  }

  document.getElementById('detailBody').innerHTML =
    gallHtml
    + '<div class="detail-badge-row">'+badges+'</div>'
    + '<div class="detail-price">'+p.price+'</div>'
    + '<div class="detail-name">'+p.name+'</div>'
    + '<div class="detail-meta">'
    +   '<span>📍 '+p.loc+'</span>'
    + '</div>'
    + (p.desc ? '<div class="detail-desc">'+p.desc+'</div>' : '')
    + '<div class="detail-stars">'+starsHtml(p.rat,14)+(p.rev?' <span>('+p.rev+' reseñas)</span>':'')+'</div>'
    + '<div class="detail-actions" id="detailActions">'+actions+'</div>'
    + '<div id="dpPayArea"></div>';

  detailPage.classList.add('open');
  detailPage.scrollTop = 0;

  // Thumb clicks
  detailPage.querySelectorAll('.detail-thumbs img').forEach(function(th){
    th.addEventListener('click', function(){
      document.getElementById('dmImg').src = this.dataset.src;
      detailPage.querySelectorAll('.detail-thumbs img').forEach(function(x){ x.classList.remove('active'); });
      this.classList.add('active');
    });
  });

  var bc2 = document.getElementById('dpBtnComprar');
  if (bc2) bc2.addEventListener('click', function(){ openDetailCheckout(p); });
