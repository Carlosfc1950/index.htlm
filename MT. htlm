function starsHtml(r, size) {
  if (!r) return '<span style="font-size:11px;color:var(--gt)">Sin reseñas</span>';
  var s = size || 12;
  return '<span style="color:#f59e0b;font-size:'+s+'px">'+('★').repeat(Math.floor(r))+'</span>';
}
function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(function(){ t.classList.remove('show'); }, 3400);
}
function goTo(id) {
  var el = document.getElementById(id);
  if (el) el.scrollIntoView({behavior:'smooth'});
}

