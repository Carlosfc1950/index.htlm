    +'<div class="fg"><label>Categoría</label><select class="fi" id="pCat"><option value="refrigeracion">Refrigeración y Aire</option><option value="lavarropas">Lavarropas</option><option value="cocinas">Cocinas y Hornos</option><option value="herramientas">Herramientas</option><option value="usados">Equipos Usados</option></select></div>'
    +'<div class="fg"><label>Precio ($) *</label><input class="fi" id="pPre" type="number" min="1" placeholder="0"></div>'
    +'</div>'
    +'<div class="fg"><label>Condición</label><div class="radio-row"><label class="ropt"><input type="radio" name="cond" value="nuevo" checked> Nuevo</label><label class="ropt"><input type="radio" name="cond" value="usado"> Usado</label><label class="ropt"><input type="radio" name="cond" value="reacondicionado"> Reacondicionado</label></div></div>'
    +'<div class="fg"><label>Descripción</label><textarea class="fi" id="pDes" rows="3" placeholder="Marca, modelo, compatibilidad..."></textarea></div>'
    +'<div class="frow">'
    +'<div class="fg"><label>Ciudad</label><select class="fi" id="pCiu"><option>Buenos Aires</option><option>Córdoba</option><option>Rosario</option><option>Mendoza</option><option>La Plata</option></select></div>'
    +'<div class="fg"><label>Tu nombre *</label><input class="fi" id="pSN" placeholder="Ej: Carlos M."></div>'
    +'</div>'
    +'<div class="fg"><label>Tu WhatsApp *</label>'
    +'<div class="ph-wrap"><span class="ph-prefix">+54 9</span><input class="ph-input" id="pWA" type="tel" placeholder="11 2345-6789" maxlength="12"></div>'
    +'<small class="ph-hint">Código de área + número. Ej: 1123456789</small></div>'
    +'<div class="ferr" id="pErr"></div>'
    +'<button class="btnblock" id="btnPub">Publicar gratis ✨</button>'
  );

  var pzone=document.getElementById('pzone');
  pzone.addEventListener('click', function(){ document.getElementById('photoInput').click(); });
  pzone.addEventListener('dragover', function(e){ e.preventDefault(); this.classList.add('dragover'); });
  pzone.addEventListener('dragleave', function(){ this.classList.remove('dragover'); });
  pzone.addEventListener('drop', function(e){ e.preventDefault(); this.classList.remove('dragover'); addPhotos(Array.from(e.dataTransfer.files).filter(function(f){return f.type.startsWith('image/');})); });

  document.getElementById('btnPub').addEventListener('click', function(){
