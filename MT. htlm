var currentCat = '';

function renderProducts(cat) {
  if (cat !== undefined) currentCat = cat;
  var list = currentCat ? products.filter(function(p){return p.cat===currentCat;}) : products;
  var g = document.getElementById('prodGrid');

  if (!list.length) {
    g.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:48px 16px;color:var(--gt)"><p style="font-size:36px;margin-bottom:10px">📦</p><p>No hay productos en esta categoría.</p></div>';
    return;
  }

  g.innerHTML = list.map(buildProductCard).join('');

  // Click → abrir página de detalle (no modal)
  g.querySelectorAll('.pcard[data-pid]').forEach(function(el){
    el.addEventListener('click', function(e){
      if (e.target.closest('.btn-wa-card') || e.target.closest('.btn-delete-card')) return;
      openDetail(+this.dataset.pid);
    });
  });
}

function buildProductCard(p) {
  var isMT = p.owner === 'mt';

  var imgHtml = p.photos.length
    ? '<img src="'+p.photos[0]+'" alt="'+p.name+'">'
    : '<div class="emoji">'+p.icon+'</div>';

  var badgeMT = isMT ? '<span class="pbadge mt">Mercado Técnico</span>' : '';

  var badgeExtra = '';
  if (p.badge) {
    var bc = p.badge==='OFERTA'?'offer': p.badge==='NUEVO'||p.badge==='NEW'?'new': p.badge==='DESTACADO'||p.badge==='MÁS VENDIDO'?'featured': 'used';
    badgeExtra = '<span class="pbadge '+bc+'" style="top:'+(isMT?'28px':'7px')+'">'+p.badge+'</span>';
  }

  var deleteBtn = adminMode
    ? '<button class="btn-delete-card" data-pid="'+p.id+'">🗑 Eliminar</button>'
    : '';

  var footer = '';
  if (!isMT && p.wa) {
    var initials = p.sellerName ? p.sellerName.split(' ').map(function(w){return w[0];}).join('').toUpperCase().slice(0,2) : '?';
    var waMsg = 'Hola, vi tu publicación de *'+p.name+'* por *'+p.price+'* en Mercado Técnico. ¿Está disponible?';
    footer = '<div class="pcard-footer">'
      + '<span class="pseller"><span class="pseller-av">'+initials+'</span>'+p.sellerName+'</span>'
      + '<a class="btn-wa-card" href="'+waLink(p.wa, waMsg)+'" target="_blank" rel="noopener noreferrer">'+WA_SM+' WA</a>'
      + '</div>';
  } else if (isMT) {
    footer = '<div class="pcard-footer"><span style="font-size:10.5px;color:var(--b);font-weight:700">🏭 Stock propio</span></div>';
  }

  return '<div class="pcard tipo-'+(isMT?'mt':'tecnico')+'" data-pid="'+p.id+'">'
    + deleteBtn
    + '<div class="pimg">'+imgHtml+badgeMT+badgeExtra+'</div>'
    + '<div class="pbody">'
    +   '<div class="pname">'+p.name+'</div>'
    +   '<div class="pprice">'+p.price+'</div>'
    +   '<div class="ploc">📍 '+p.loc+'</div>'
    +   '<div class="stars">'+starsHtml(p.rat)+(p.rev?' <span>('+p.rev+')</span>':'')+'</div>'
    + '</div>'
    + footer
    + '</div>';
}

