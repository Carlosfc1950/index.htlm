document.getElementById('photoInput').addEventListener('change', function(){ addPhotos(Array.from(this.files)); this.value=''; });

function addPhotos(files) {
  var errEl=document.getElementById('photoErr'); if(!errEl) return;
  var space=8-uploadedPhotos.length; if(space<=0){errEl.textContent='Máximo 8 fotos.';return;}
  files.slice(0,space).forEach(function(f){
    if(f.size>10*1024*1024){errEl.textContent='Foto demasiado grande (máx. 10 MB).';return;}
    var r=new FileReader(); r.onload=function(e){uploadedPhotos.push(e.target.result);refreshPhotoGrid();}; r.readAsDataURL(f);
  });
}

function refreshPhotoGrid() {
  var grid=document.getElementById('pgrid'), zone=document.getElementById('pzone'); if(!grid)return;
  if(!uploadedPhotos.length){grid.innerHTML='';if(zone)zone.style.display='';return;}
  if(zone)zone.style.display='none';
  grid.innerHTML=uploadedPhotos.map(function(src,i){
    return '<div class="pthumb'+(i===0?' pmain':'')+'"><img src="'+src+'" data-i="'+i+'" alt="">'+(i===0?'<div class="pmainbadge">Principal</div>':'')+'<button class="prmv" data-i="'+i+'">✕</button></div>';
  }).join('')+(uploadedPhotos.length<8?'<div class="paddmore" id="addMore"><span>+</span><small>Agregar</small></div>':'');
  grid.querySelectorAll('.pthumb img').forEach(function(img){
    img.addEventListener('click',function(){var i=+this.dataset.i;if(i===0)return;uploadedPhotos.unshift(uploadedPhotos.splice(i,1)[0]);refreshPhotoGrid();});
  });
  grid.querySelectorAll('.prmv').forEach(function(btn){
    btn.addEventListener('click',function(e){e.stopPropagation();uploadedPhotos.splice(+this.dataset.i,1);refreshPhotoGrid();});
  });
  var am=document.getElementById('addMore'); if(am) am.addEventListener('click',function(){document.getElementById('photoInput').click();});
}

