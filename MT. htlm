<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mercado Técnico</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --y:#FFD600;--b:#1a3a8c;--bd:#122870;--dk:#111827;
  --gr:#f4f6fb;--gm:#e2e8f0;--gt:#6b7280;--wh:#fff;
  --gn:#16a34a;--rd:#dc2626;
  --fd:'Barlow Condensed',sans-serif;--fb:'Barlow',sans-serif;
  --sh:0 1px 3px rgba(0,0,0,.08),0 4px 12px rgba(0,0,0,.06);
  --shh:0 8px 32px rgba(0,0,0,.14);--r:12px
}
body{font-family:var(--fb);color:var(--dk);background:#fff;min-height:100vh}

/* ── TOPBAR ── */
.topbar{background:var(--dk);color:#94a3b8;font-size:11.5px;padding:6px 16px;text-align:center;letter-spacing:.3px}

/* ── ADMIN BAR ── */
.admin-bar{display:none;background:#dc2626;color:#fff;padding:8px 20px;font-size:13px;font-weight:700;letter-spacing:.3px;position:sticky;top:0;z-index:101}
.admin-bar.show{display:flex;align-items:center;justify-content:center;gap:16px}
.btn-admin-exit{background:rgba(255,255,255,.2);border:none;color:#fff;font-size:12px;font-weight:700;padding:5px 13px;border-radius:6px;cursor:pointer}
.btn-admin-exit:hover{background:rgba(255,255,255,.35)}

/* ── HEADER ── */
header{background:var(--y);padding:10px 0;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(0,0,0,.15)}
.admin-bar.show ~ header{top:36px}
.hi{max-width:1240px;margin:0 auto;padding:0 16px;display:flex;align-items:center;gap:12px}
.logo{display:flex;align-items:center;gap:9px;text-decoration:none;flex-shrink:0}
.logo-box{width:40px;height:40px;background:var(--b);border-radius:9px;display:flex;align-items:center;justify-content:center}
.logo-box svg{width:22px;height:22px;fill:var(--y)}
.logo-txt strong{display:block;font-family:var(--fd);font-size:21px;font-weight:900;color:var(--b);line-height:1}
.logo-txt span{font-family:var(--fd);font-size:12px;font-weight:700;color:#2549b0;letter-spacing:.5px}
.searchbar{flex:1;display:flex;background:#fff;border-radius:9px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.12)}
.searchbar input{flex:1;border:none;padding:11px 14px;font-family:var(--fb);font-size:14px;outline:none;color:var(--dk)}
.searchbar button{background:var(--b);border:none;padding:0 16px;cursor:pointer;transition:background .2s}
.searchbar button:hover{background:var(--bd)}
.searchbar button svg{width:18px;height:18px;fill:#fff;display:block}
.hactions{display:flex;align-items:center;gap:8px;flex-shrink:0}
.btnlink{font-family:var(--fb);font-size:13px;font-weight:600;color:var(--b);background:none;border:none;cursor:pointer;display:flex;align-items:center;gap:5px;padding:8px 10px;border-radius:8px;transition:background .2s;white-space:nowrap}
.btnlink:hover{background:rgba(26,58,140,.10)}
.btnlink svg{width:17px;height:17px;fill:var(--b)}
.btnprimary{background:var(--b);color:#fff;font-family:var(--fd);font-size:15px;font-weight:700;border:none;padding:10px 20px;border-radius:9px;cursor:pointer;transition:background .2s;white-space:nowrap}
.btnprimary:hover{background:var(--bd)}

/* ── NAV ── */
nav{background:var(--b);border-bottom:3px solid var(--y)}
.ni{max-width:1240px;margin:0 auto;padding:0 16px;display:flex;overflow-x:auto;scrollbar-width:none}
.ni::-webkit-scrollbar{height:0}
.nitem{font-family:var(--fb);font-size:13px;font-weight:600;color:rgba(255,255,255,.75);padding:11px 14px;cursor:pointer;white-space:nowrap;border-bottom:3px solid transparent;margin-bottom:-3px;flex-shrink:0;transition:color .2s}
.nitem:hover,.nitem.active{color:var(--y);border-bottom-color:var(--y)}
.nitem.contact{margin-left:auto;color:var(--y)}
.nitem.contact:hover{color:#fff}

/* ── HERO ── */
.hero{background:var(--y);padding:32px 0 0}
.hero-in{max-width:1240px;margin:0 auto;padding:0 16px;display:grid;grid-template-columns:1fr 1fr auto;gap:24px;align-items:end}
.hero-txt{padding-bottom:40px}
.hero-txt h1{font-family:var(--fd);font-size:52px;font-weight:900;line-height:.95;margin-bottom:14px;letter-spacing:-1px}
.hero-txt p{font-size:15px;color:#1e293b;margin-bottom:24px;line-height:1.55}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap}
.btn-hy{background:var(--b);color:#fff;font-family:var(--fd);font-size:16px;font-weight:700;padding:13px 28px;border-radius:9px;border:none;cursor:pointer;transition:background .2s}
.btn-hy:hover{background:var(--bd)}
.btn-ho{background:#fff;color:var(--b);font-family:var(--fd);font-size:16px;font-weight:700;padding:13px 28px;border-radius:9px;border:2.5px solid var(--b);cursor:pointer;transition:background .2s,color .2s}
.btn-ho:hover{background:var(--b);color:#fff}
.hero-chips{background:rgba(26,58,140,.08);border-radius:16px 16px 0 0;padding:20px;display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.chip{background:#fff;border-radius:9px;padding:10px 4px;text-align:center;font-size:11px;font-weight:700;color:var(--b);cursor:pointer;box-shadow:var(--sh);transition:transform .15s}
.chip:hover{transform:translateY(-2px)}
.chip span{display:block;font-size:22px;margin-bottom:4px}
.hero-feats{background:#fff;border-radius:14px;padding:20px 18px;display:flex;flex-direction:column;gap:14px;box-shadow:var(--sh);margin-bottom:40px}
.hfeat{display:flex;align-items:center;gap:12px}
.hfeat-icon{width:36px;height:36px;background:var(--gr);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.hfeat-txt strong{display:block;font-size:13px;font-weight:700}
.hfeat-txt span{font-size:12px;color:var(--gt)}

/* ── CATS ── */
.cats{background:#fff;border-bottom:1px solid var(--gm);padding:18px 0}
.cats-in{max-width:1240px;margin:0 auto;padding:0 16px;display:flex;gap:10px;overflow-x:auto;scrollbar-width:none}
.cats-in::-webkit-scrollbar{height:0}
.catcard{flex-shrink:0;border:1.5px solid var(--gm);border-radius:var(--r);padding:12px 16px;display:flex;align-items:center;gap:10px;cursor:pointer;min-width:155px;transition:border-color .2s,box-shadow .2s,transform .15s;background:#fff}
.catcard:hover{border-color:var(--b);box-shadow:var(--shh);transform:translateY(-2px)}
.catcard .ci{font-size:26px}
.catcard strong{display:block;font-size:12.5px;font-weight:700}
.catcard small{font-size:11px;color:var(--gt)}
.catcard a{font-size:11px;color:var(--b);display:block;margin-top:2px;font-weight:600}

/* ── SECTIONS ── */
.sec{padding:28px 0}
.sec.gray{background:var(--gr)}
.sec-in{max-width:1240px;margin:0 auto;padding:0 16px}
.sec-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.sec-hd h2{font-family:var(--fd);font-size:28px;font-weight:800}
.seeall{font-size:13px;font-weight:700;color:var(--b);cursor:pointer;text-decoration:none}

/* ── LAYOUT ── */
.prodlayout{display:grid;grid-template-columns:1fr 272px;gap:20px;align-items:start}

/* ══════════════════════════════════════════════
   PRODUCT GRID — damero responsive
   Desktop: 4 col · Tablet: 3 col · Móvil: 2 col
══════════════════════════════════════════════ */
.prodgrid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:12px;
}
@media(max-width:1100px){.prodgrid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:700px) {.prodgrid{grid-template-columns:repeat(2,1fr);gap:10px}}

/* ══════════════════════════════════════════════
   PRODUCT CARDS — dos tipos visuales
══════════════════════════════════════════════ */
.pcard{
  background:#fff;border:1.5px solid var(--gm);border-radius:var(--r);
  overflow:hidden;cursor:pointer;position:relative;
  transition:border-color .2s,box-shadow .2s,transform .2s;
  display:flex;flex-direction:column;
}
.pcard:hover{border-color:var(--b);box-shadow:var(--shh);transform:translateY(-3px)}
.pcard.tipo-mt     {border-top:3px solid var(--b)}
.pcard.tipo-tecnico{border-top:3px solid var(--y)}

.pimg{height:130px;background:var(--gr);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;flex-shrink:0}
.pimg img{width:100%;height:100%;object-fit:cover}
.pimg .emoji{font-size:44px}

.pbadge{position:absolute;top:7px;left:7px;font-size:10px;font-weight:800;padding:3px 7px;border-radius:5px;letter-spacing:.3px}
.pbadge.mt      {background:var(--b);color:#fff}
.pbadge.offer   {background:var(--rd);color:#fff}
.pbadge.new     {background:var(--gn);color:#fff}
.pbadge.featured{background:#7c3aed;color:#fff}
.pbadge.used    {background:#64748b;color:#fff}

.pbody{padding:10px 11px;display:flex;flex-direction:column;gap:3px;flex:1}
.pname{font-size:12.5px;font-weight:600;line-height:1.3;color:var(--dk)}
.pprice{font-family:var(--fd);font-size:22px;font-weight:800;color:var(--dk);line-height:1.1}
.ploc{font-size:11px;color:var(--gt)}
.stars{color:#f59e0b;font-size:11px;display:flex;align-items:center;gap:2px}
.stars span{color:var(--gt);font-size:10.5px}

.pcard-footer{padding:0 11px 10px;display:flex;align-items:center;justify-content:space-between;gap:6px;margin-top:auto}
.pseller{font-size:11px;font-weight:600;color:var(--b);display:flex;align-items:center;gap:4px;min-width:0;overflow:hidden}
.pseller-av{width:20px;height:20px;border-radius:50%;background:var(--b);color:#fff;font-family:var(--fd);font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.btn-wa-card{background:#25D366;color:#fff;font-size:10.5px;font-weight:700;padding:5px 9px;border-radius:6px;border:none;cursor:pointer;display:flex;align-items:center;gap:3px;text-decoration:none;white-space:nowrap;transition:background .2s;flex-shrink:0}
.btn-wa-card:hover{background:#1ebe5d}
.btn-wa-card svg{width:11px;height:11px;fill:#fff;flex-shrink:0}

/* ── ADMIN delete button ── */
.btn-delete-card{display:none;position:absolute;top:6px;right:6px;background:#dc2626;color:#fff;border:none;border-radius:6px;font-size:11px;font-weight:800;padding:4px 9px;cursor:pointer;z-index:10;line-height:1.4;transition:background .2s}
.btn-delete-card:hover{background:#b91c1c}
.admin-mode .pcard{position:relative}
.admin-mode .btn-delete-card{display:block}

/* ── SIDEBAR ── */
.sidebar{display:flex;flex-direction:column;gap:14px}
.sb-yellow{background:var(--y);border-radius:var(--r);padding:20px;text-align:center}
.sb-yellow h3{font-family:var(--fd);font-size:22px;font-weight:900;color:var(--b);margin-bottom:6px}
.sb-yellow p{font-size:13px;color:#1e293b;margin-bottom:14px;line-height:1.5}
.sb-white{background:#fff;border:1.5px solid var(--gm);border-radius:var(--r);padding:16px}
.sb-white h4{font-family:var(--fd);font-size:19px;font-weight:800;margin-bottom:12px}
.fsel{width:100%;padding:10px 11px;border:1.5px solid var(--gm);border-radius:8px;font-family:var(--fb);font-size:13px;background:#fff;margin-bottom:10px;outline:none;cursor:pointer;transition:border-color .2s}
.fsel:focus{border-color:var(--b)}
.btnblock{width:100%;background:var(--b);color:#fff;font-family:var(--fd);font-size:16px;font-weight:700;padding:11px;border-radius:9px;border:none;cursor:pointer;transition:background .2s}
.btnblock:hover{background:var(--bd)}
.btnoutline{width:100%;background:#fff;color:var(--b);font-family:var(--fd);font-size:14px;font-weight:700;padding:10px;border-radius:9px;border:2.5px solid var(--b);cursor:pointer;transition:background .2s,color .2s}
.btnoutline:hover{background:var(--b);color:#fff}
.btnwa-block{width:100%;background:#25D366;color:#fff;font-family:var(--fd);font-size:15px;font-weight:700;padding:11px;border-radius:9px;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;transition:background .2s}
.btnwa-block:hover{background:#1ebe5d}
.btnwa-block svg{width:18px;height:18px;fill:#fff;flex-shrink:0}
.seeall-sm{display:block;text-align:center;font-size:12px;color:var(--b);margin-top:10px;cursor:pointer;font-weight:600}

/* ── TECHNICIANS ── */
.techgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px}
.tcard{background:#fff;border:1.5px solid var(--gm);border-radius:var(--r);padding:18px;transition:border-color .2s,box-shadow .2s,transform .2s;border-top:3px solid var(--y)}
.tcard:hover{border-color:#e6c000;box-shadow:var(--shh);transform:translateY(-2px)}
.thead2{display:flex;align-items:center;gap:12px;margin-bottom:11px}
.tavatar{width:48px;height:48px;border-radius:50%;background:var(--b);color:#fff;font-family:var(--fd);font-size:20px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.tname strong{display:block;font-size:14px;font-weight:700}
.tname small{font-size:12px;color:var(--gt);display:block;margin-top:1px}
.ttags{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:11px}
.tag{background:#eef2ff;color:var(--b);font-size:11px;font-weight:700;padding:3px 8px;border-radius:5px}
.tfoot{display:flex;align-items:center;justify-content:space-between;gap:8px}
.btnwa{background:#25D366;color:#fff;font-size:12px;font-weight:700;padding:6px 12px;border-radius:7px;border:none;cursor:pointer;display:flex;align-items:center;gap:5px;text-decoration:none;transition:background .2s;white-space:nowrap}
.btnwa:hover{background:#1ebe5d}
.btnwa svg{width:13px;height:13px;fill:#fff;flex-shrink:0}

/* ── COURSES ── */
.crgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px}
.crcard{background:#fff;border:1.5px solid var(--gm);border-radius:var(--r);overflow:hidden;cursor:pointer;transition:border-color .2s,box-shadow .2s,transform .2s}
.crcard:hover{border-color:#e6c000;box-shadow:var(--shh);transform:translateY(-2px)}
.crimg{background:linear-gradient(135deg,var(--b),#2549b0);height:100px;display:flex;align-items:center;justify-content:center;font-size:40px;position:relative}
.crmode{position:absolute;top:8px;right:8px;background:var(--y);color:var(--b);font-size:10px;font-weight:800;padding:3px 8px;border-radius:5px}
.crbody{padding:14px}
.crbody h4{font-size:14px;font-weight:700;margin-bottom:4px;line-height:1.3}
.inst{font-size:12px;color:var(--gt);margin-bottom:9px}
.crfoot{display:flex;align-items:center;justify-content:space-between}
.crprice{font-family:var(--fd);font-size:19px;font-weight:800;color:var(--b)}
.crprice.free{color:var(--gn)}

/* ── CONTACT SECTION ── */
.contact-sec{background:var(--b);padding:40px 0}
.contact-in{max-width:680px;margin:0 auto;padding:0 20px;text-align:center}
.contact-in h2{font-family:var(--fd);font-size:36px;font-weight:900;color:#fff;margin-bottom:10px}
.contact-in p{font-size:15px;color:rgba(255,255,255,.7);margin-bottom:28px;line-height:1.6}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px}
.contact-item{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:12px;padding:18px;text-align:center}
.contact-item .ico{font-size:28px;margin-bottom:8px}
.contact-item strong{display:block;font-size:14px;font-weight:700;color:#fff;margin-bottom:4px}
.contact-item span{font-size:13px;color:rgba(255,255,255,.6)}
.contact-item a{color:var(--y);text-decoration:none;font-weight:700}
.contact-item a:hover{text-decoration:underline}
.btn-wa-contact{display:inline-flex;align-items:center;gap:10px;background:#25D366;color:#fff;font-family:var(--fd);font-size:18px;font-weight:800;padding:15px 36px;border-radius:10px;text-decoration:none;transition:background .2s}
.btn-wa-contact:hover{background:#1ebe5d}
.btn-wa-contact svg{width:22px;height:22px;fill:#fff}

/* ── VALUE PROPS ── */
.vp{background:var(--gr);padding:26px 0;border-top:1px solid var(--gm)}
.vpgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:18px}
.vpi{display:flex;align-items:center;gap:10px}
.vpi .ico{font-size:26px}
.vpi strong{display:block;font-size:13px;font-weight:700}
.vpi span{font-size:12px;color:var(--gt)}

/* ── FOOTER ── */
footer{background:var(--dk);color:rgba(255,255,255,.6);padding:36px 0 18px}
.fin{max-width:1240px;margin:0 auto;padding:0 16px}
.fgrid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:28px;margin-bottom:28px}
.fbrand p{font-size:13px;margin-top:10px;line-height:1.65}
.fcol h5{font-family:var(--fd);font-size:15px;font-weight:800;color:#fff;margin-bottom:11px;letter-spacing:.3px}
.fcol ul{list-style:none;display:flex;flex-direction:column;gap:7px}
.fcol ul li a{font-size:13px;color:rgba(255,255,255,.5);text-decoration:none;cursor:pointer;transition:color .2s}
.fcol ul li a:hover{color:var(--y)}
.fbot{border-top:1px solid rgba(255,255,255,.08);padding-top:14px;display:flex;justify-content:space-between;align-items:center;font-size:12px;flex-wrap:wrap;gap:8px}

/* Admin gear in footer — visible but subtle */
.admin-gear{
  background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);
  color:rgba(255,255,255,.5);font-size:13px;font-weight:700;
  padding:5px 12px;border-radius:6px;cursor:pointer;
  display:flex;align-items:center;gap:5px;
  transition:background .2s,color .2s;
  user-select:none;
}
.admin-gear:hover{background:rgba(255,255,255,.15);color:#fff}
.admin-gear.active{background:var(--rd);color:#fff;border-color:var(--rd)}

/* ── OVERLAY & MODAL ── */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:300;align-items:center;justify-content:center;padding:16px}
.overlay.open{display:flex}
.modal{background:#fff;border-radius:16px;padding:28px;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;position:relative;box-shadow:0 20px 60px rgba(0,0,0,.25)}
.mclose{position:absolute;top:13px;right:14px;background:none;border:none;font-size:22px;cursor:pointer;color:var(--gt);line-height:1;width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:background .2s}
.mclose:hover{background:var(--gr)}
.modal h3{font-family:var(--fd);font-size:25px;font-weight:800;margin-bottom:5px}
.mdesc{font-size:14px;color:var(--gt);margin-bottom:18px;line-height:1.5}
.mtabs{display:flex;border:1.5px solid var(--gm);border-radius:9px;overflow:hidden;margin-bottom:18px}
.mtab{flex:1;padding:10px;text-align:center;font-size:14px;font-weight:700;cursor:pointer;background:#fff;border:none;font-family:var(--fb);transition:background .2s,color .2s}
.mtab.active{background:var(--b);color:#fff}
.fg{margin-bottom:14px}
.fg label{display:block;font-size:13px;font-weight:700;margin-bottom:5px;color:var(--dk)}
.fi{width:100%;padding:10px 12px;border:1.5px solid var(--gm);border-radius:8px;font-family:var(--fb);font-size:14px;outline:none;transition:border-color .2s;color:var(--dk)}
.fi:focus{border-color:var(--b)}
textarea.fi{resize:vertical}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.ferr{color:var(--rd);font-size:13px;margin-bottom:11px;display:none;padding:9px 12px;background:#fef2f2;border-radius:7px;border:1px solid #fecaca}
.radio-row{display:flex;gap:8px;flex-wrap:wrap}
.ropt{display:flex;align-items:center;gap:6px;font-size:13px;font-weight:600;cursor:pointer;padding:7px 12px;border:1.5px solid var(--gm);border-radius:8px;transition:border-color .2s,background .2s}
.ropt input{accent-color:var(--b);cursor:pointer}
.ropt:has(input:checked){border-color:var(--b);background:#eef2ff;color:var(--b)}

/* Phone field */
.ph-wrap{display:flex;align-items:stretch;border:1.5px solid var(--gm);border-radius:8px;overflow:hidden;transition:border-color .2s}
.ph-wrap:focus-within{border-color:var(--b)}
.ph-prefix{padding:0 12px;background:#f0f4ff;color:var(--b);font-weight:800;font-size:13px;border-right:1.5px solid var(--gm);display:flex;align-items:center;white-space:nowrap;flex-shrink:0}
.ph-input{flex:1;border:none;padding:10px 12px;font-family:var(--fb);font-size:14px;outline:none;color:var(--dk);min-width:0}
.ph-hint{display:block;margin-top:4px;font-size:11px;color:var(--gt)}

/* Photos */
.pzone{border:2.5px dashed var(--gm);border-radius:11px;padding:28px 14px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;cursor:pointer;background:var(--gr);transition:border-color .2s,background .2s;text-align:center;user-select:none}
.pzone:hover,.pzone.dragover{border-color:var(--b);background:#eef2ff}
.pzone .pzico{font-size:36px}
.pzone strong{font-size:14px;color:var(--b);font-weight:700}
.pzone small{font-size:12px;color:var(--gt)}
.pgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:10px}
.pthumb{position:relative;border-radius:8px;overflow:hidden;aspect-ratio:1;border:2px solid var(--gm);cursor:pointer;transition:border-color .2s}
.pthumb:hover{border-color:var(--b)}
.pthumb.pmain{border-color:var(--b);border-width:2.5px}
.pthumb img{width:100%;height:100%;object-fit:cover;display:block}
.pmainbadge{position:absolute;bottom:0;left:0;right:0;background:rgba(26,58,140,.88);color:#fff;font-size:10px;font-weight:800;text-align:center;padding:3px}
.prmv{position:absolute;top:3px;right:3px;width:20px;height:20px;background:rgba(0,0,0,.7);color:#fff;border:none;border-radius:50%;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0;line-height:1;transition:background .2s}
.prmv:hover{background:var(--rd)}
.paddmore{border:2px dashed var(--gm);border-radius:8px;aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;color:var(--gt);font-size:20px;gap:2px;transition:border-color .2s,color .2s}
.paddmore:hover{border-color:var(--b);color:var(--b)}
.paddmore small{font-size:11px}
.photoerr{color:var(--rd);font-size:12px;margin-top:5px}

/* ── PRODUCT DETAIL PAGE (full screen overlay) ── */
.detail-page{
  display:none;position:fixed;inset:0;background:#fff;
  z-index:400;overflow-y:auto;
}
.detail-page.open{display:block}
.detail-header{background:var(--y);padding:12px 16px;display:flex;align-items:center;gap:12px;position:sticky;top:0;z-index:10;box-shadow:0 2px 8px rgba(0,0,0,.1)}
.detail-back{background:var(--b);color:#fff;border:none;border-radius:8px;padding:8px 14px;font-family:var(--fd);font-size:15px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:6px}
.detail-back:hover{background:var(--bd)}
.detail-title{font-family:var(--fd);font-size:17px;font-weight:800;color:var(--b);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.detail-body{max-width:680px;margin:0 auto;padding:20px 16px 40px}
.detail-gallery{margin-bottom:18px}
.detail-main-img{width:100%;height:260px;object-fit:cover;border-radius:12px;display:block;margin-bottom:8px}
.detail-main-emoji{width:100%;height:200px;background:var(--gr);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:80px;margin-bottom:8px}
.detail-thumbs{display:flex;gap:8px;overflow-x:auto;padding-bottom:2px}
.detail-thumbs img{width:60px;height:60px;object-fit:cover;border-radius:8px;cursor:pointer;border:2px solid var(--gm);flex-shrink:0;transition:border-color .2s}
.detail-thumbs img.active{border-color:var(--b)}
.detail-badge-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px}
.detail-badge{font-size:11px;font-weight:800;padding:3px 10px;border-radius:5px;letter-spacing:.3px}
.detail-badge.mt      {background:var(--b);color:#fff}
.detail-badge.tecnico {background:var(--y);color:var(--b)}
.detail-badge.offer   {background:var(--rd);color:#fff}
.detail-badge.new     {background:var(--gn);color:#fff}
.detail-badge.featured{background:#7c3aed;color:#fff}
.detail-price{font-family:var(--fd);font-size:38px;font-weight:900;color:var(--dk);line-height:1;margin-bottom:6px}
.detail-name{font-size:18px;font-weight:700;line-height:1.3;margin-bottom:10px;color:var(--dk)}
.detail-meta{display:flex;flex-direction:column;gap:5px;margin-bottom:14px}
.detail-meta span{font-size:13px;color:var(--gt);display:flex;align-items:center;gap:5px}
.detail-desc{font-size:14px;color:#374151;line-height:1.7;margin-bottom:20px;padding:14px;background:var(--gr);border-radius:10px}
.detail-stars{display:flex;align-items:center;gap:6px;font-size:14px;color:#f59e0b;margin-bottom:22px}
.detail-stars span{color:var(--gt);font-size:13px}
.detail-actions{display:flex;flex-direction:column;gap:11px}
.pay-opts{display:flex;flex-direction:column;gap:10px;margin-bottom:18px}
.pay-opt{border:2px solid var(--gm);border-radius:11px;padding:13px 16px;cursor:pointer;display:flex;align-items:center;gap:14px;transition:border-color .2s,background .2s}
.pay-opt:hover{border-color:var(--b);background:#f8f9ff}
.pay-opt.sel{border-color:var(--b);background:#eef2ff}
.pay-opt-ico{font-size:26px;flex-shrink:0}
.pay-opt-txt strong{display:block;font-size:14px;font-weight:700}
.pay-opt-txt span{font-size:12px;color:var(--gt)}
.pay-detail{background:var(--gr);border-radius:10px;padding:14px;margin-bottom:16px;font-size:13px;line-height:1.85}
.pay-detail strong{display:block;font-size:14px;font-weight:800;margin-bottom:7px}
.pay-warn{background:#fffbeb;border:1.5px solid var(--y);border-radius:10px;padding:14px;margin-bottom:16px;font-size:13px;line-height:1.75}
.pay-warn strong{display:block;font-weight:800;margin-bottom:6px}
.secure{text-align:center;font-size:11px;color:var(--gt);margin-top:10px}

/* ── MODAL for login/tech/publish ── */
.gall-main{width:100%;height:220px;object-fit:cover;display:block;border-radius:9px;margin-bottom:8px}
.gall-thumbs{display:flex;gap:7px;overflow-x:auto;margin-bottom:16px;padding-bottom:2px}
.gall-thumbs img{width:54px;height:54px;object-fit:cover;border-radius:7px;cursor:pointer;border:2px solid var(--gm);flex-shrink:0;transition:border-color .2s}
.gall-thumbs img.active{border-color:var(--b)}

/* Toast */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(16px);background:var(--dk);color:#fff;padding:12px 24px;border-radius:30px;font-size:14px;font-weight:600;z-index:500;opacity:0;transition:opacity .3s,transform .3s;white-space:nowrap;box-shadow:var(--shh);pointer-events:none}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ── RESPONSIVE ── */
