function doSearch() {
  var q=document.getElementById('searchInput').value.trim().toLowerCase();
  if (!q){ renderProducts(''); return; }
  var found=products.filter(function(p){
    return p.name.toLowerCase().indexOf(q)>-1||p.cat.indexOf(q)>-1||(p.desc&&p.desc.toLowerCase().indexOf(q)>-1);
  });
  var g=document.getElementById('prodGrid');
  if (!found.length) {
    g.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:48px 16px;color:var(--gt)"><p style="font-size:36px;margin-bottom:10px">🔍</p><p>Sin resultados para <strong>'+q+'</strong></p></div>';
  } else {
    g.innerHTML=found.map(buildProductCard).join('');
    g.querySelectorAll('.pcard[data-pid]').forEach(function(el){
      el.addEventListener('click',function(e){
        if(e.target.closest('.btn-wa-card')||e.target.closest('.btn-delete-card'))return;
        openDetail(+this.dataset.pid);
      });
    });
  }
  goTo('productos');
}

